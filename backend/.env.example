# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (supports Local & Neon PG)
DATABASE_URL=postgresql://postgres:postgres@localhost:5443/erv_db

# Security & Session Authentication
JWT_SECRET=super_secret_change_me_in_production_123456
JWT_EXPIRES_IN=7d

# Cloudinary Integration (Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS & Frontend Origins
FRONTEND_URL=http://localhost:5173

# Initial Administrator Bootstrapping (Checked on startup; created if no admins exist)
ADMIN_EMAIL=admin@ervision.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_NAME="System Administrator"
